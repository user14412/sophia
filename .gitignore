# 环境与密钥
.env

# Python 缓存与编译文件
__pycache__/

# VS Code 配置
.vscode/

# 媒体文件（保留目录结构，通过 .gitkeep 占位）
resources/fonts/*
!resources/fonts/.gitkeep
resources/images/*
!resources/images/.gitkeep
resources/videos/*
!resources/videos/.gitkeep
resources/voice/*
!resources/voice/.gitkeep

# 模型文件
asset/*
src/asset/*
!src/asset/.gitkeep
models/*
!models/.gitkeep

# 数据库文件
src/chromadb/*
!src/chromadb/.gitkeep

*.mp4
*.mp3
*.wav